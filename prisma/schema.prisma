generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Institution {
  id    Int    @id @default(autoincrement())
  name  String

  users User[]
  groups Group[]
  subjects Subject[]
  buildings Building[]
  bellTemplates BellTemplate[]
  schedules     Schedule[]

  @@map("institutions")
}

model Building {
  id    Int    @id @default(autoincrement())
  institutionId Int     @map("institution_id")
  name String 

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)

  floors Floor[]

  @@map("buildings")
}

model Floor {
  id    Int    @id @default(autoincrement())
  buildingId Int @map("building_id")
  number Int

  building Building @relation(fields: [buildingId], references: [id], onDelete: Restrict)

  classrooms Classroom[]

  // Номер этажа уникален в рамках одного здания
  @@unique([buildingId, number])
  @@map("floors")
}

model Classroom {
  id    Int    @id @default(autoincrement())
  floorId Int @map("floor_id")
  name String

  floor Floor @relation(fields: [floorId], references: [id], onDelete: Restrict)
  schedules Schedule[]

  // Название аудитории уникально в рамках одного этажа
  @@unique([floorId, name])
  @@map("classrooms")
}

model User {
  id            Int     @id @default(autoincrement())
  institutionId Int     @map("institution_id")
  name          String
  surname       String
  patronymic    String?
  email         String  @unique
  password      String
  roles         Role[]
  isActivated   Boolean @default(false) @map("is_activated")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  moderator   Moderator?
  teacher     Teacher?
  student     Student?
  token       Token[]

  @@map("users")
}

enum Role {
  ADMIN
  STUDENT
  TEACHER
  MODERATOR
}

model Token {
  id      Int      @id @default(autoincrement())
  token   String   @unique
  expires DateTime
  userId  Int      @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

model Moderator {
  id           Int  @id @default(autoincrement())
  userId       Int  @unique @map("user_id")
  accessRights Json @map("access_rights")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("moderators")
}

model Teacher {
  id              Int  @id @default(autoincrement())
  userId          Int  @unique @map("user_id")
  mentoredGroupId Int? @unique @map("mentored_group_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [mentoredGroupId], references: [id], onDelete: SetNull)
  teacherSubjects TeacherSubject[]
  schedules       Schedule[]

  @@map("teachers")
}

model Student {
  id      Int  @id @default(autoincrement())
  userId  Int  @unique @map("user_id")
  groupId Int? @map("group_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@map("students")
}

model Group {
  id Int @id @default(autoincrement())
  name String
  institutionId Int @map("institution_id")


  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  students Student[]
  teacher Teacher?
  subjectGroups SubjectGroup[]
  bellTemplates BellTemplate[]
  schedules     Schedule[]

  @@unique([institutionId, name])
 
  @@map("groups")
}

model Subject {
  id Int @id @default(autoincrement())
  institutionId Int @map("institution_id")
  name String

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  subjectGroups SubjectGroup[]
  teacherSubjects TeacherSubject[]
  schedules      Schedule[]

  @@unique([institutionId, name])
  
  @@map("subjects")
}

model SubjectGroup {
  id Int @id @default(autoincrement())
  subjectId Int @map("subject_id")
  groupId Int @map("group_id")

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([subjectId, groupId])

  @@map("subject_groups")
}

model TeacherSubject {
  id Int @id @default(autoincrement())
  teacherId Int @map("teacher_id")
  subjectId Int @map("subject_id")

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])

  @@map("teacher_subjects")
}

model BellTemplate {
  id             Int          @id @default(autoincrement())
  institutionId  Int          @map("institution_id")
  groupId        Int?         @map("group_id")
  scheduleType   ScheduleType @map("schedule_type")
  specificDate   DateTime?    @map("specific_date")   // используется, если scheduleType = 'date'
  weekdayStart   Int?         @map("weekday_start")  // 1 = понедельник, используется, если scheduleType = 'weekday'
  weekdayEnd     Int?         @map("weekday_end")     // 7 = воскресенье, используется, если scheduleType = 'weekday'
  lessonNumber   Int          @map("lesson_number")
  startTime      DateTime     @map("start_time")      // время начала пары (часы и минуты)
  endTime        DateTime     @map("end_time")        // время конца пары (часы и минуты)
  secondStartTime DateTime?   @map("second_start_time") // необязательное начало второго сегмента занятия
  secondEndTime   DateTime?   @map("second_end_time")   // необязательный конец второго сегмента занятия

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  group       Group?      @relation(fields: [groupId], references: [id], onDelete: SetNull)
  schedules   Schedule[]

  @@map("bell_templates")
}

model Schedule {
  id              Int          @id @default(autoincrement())
  institutionId   Int          @map("institution_id")
  subjectId       Int          @map("subject_id")
  groupId         Int          @map("group_id")
  teacherId       Int          @map("teacher_id")
  classroomId     Int?         @map("classroom_id")
  type            ScheduleClassType?
  bellTemplateId  Int          @map("bell_template_id")
  scheduleDate    DateTime     @map("schedule_date")
  // Слот занятия: записи с одним scheduleSlotId — одно занятие (подгруппы), null = одно занятие без подгрупп
  scheduleSlotId  String?       @map("schedule_slot_id")

  institution  Institution  @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teacher     Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classroom   Classroom?   @relation(fields: [classroomId], references: [id], onDelete: SetNull)
  bellTemplate BellTemplate @relation(fields: [bellTemplateId], references: [id], onDelete: Restrict)

  @@index([groupId, scheduleDate])
  @@index([classroomId, scheduleDate])
  @@index([teacherId, scheduleDate])
  @@index([scheduleSlotId])
  @@map("schedules")
}

// Enum для scheduleType
enum ScheduleType {
  date
  weekday
}

enum ScheduleClassType {
  ONLINE
  TEST
  EXAM
  DISTANCE
}