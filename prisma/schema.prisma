generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Institution {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]

  @@map("institutions")
}

model User {
  id            Int     @id @default(autoincrement())
  institutionId Int     @map("institution_id")
  name          String
  surname       String
  patronymic    String?
  email         String  @unique
  password      String
  roles         Role[]
  isActivated   Boolean @default(false) @map("is_activated")

  // Отношения
  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  moderator   Moderator?
  teacher     Teacher?
  student     Student?
  token       Token[]

  @@map("users")
}

enum Role {
  ADMIN
  STUDENT
  TEACHER
  MODERATOR
}

model Token {
  id      Int      @id @default(autoincrement())
  token   String   @unique
  expires DateTime
  userId  Int      @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

model Moderator {
  id           Int  @id @default(autoincrement())
  userId       Int  @unique @map("user_id")
  accessRights Json @map("access_rights")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("moderators")
}

model Teacher {
  id              Int  @id @default(autoincrement())
  userId          Int  @unique @map("user_id")
  mentoredGroupId Int? @unique @map("mentored_group_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teachers")
}

model Student {
  id      Int  @id @default(autoincrement())
  userId  Int  @unique @map("user_id")
  groupId Int? @map("group_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("students")
}
