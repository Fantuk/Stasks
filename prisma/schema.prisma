generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Institution {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]
  groups Group[]
  subjects Subject[]

  @@map("institutions")
}

model User {
  id            Int     @id @default(autoincrement())
  institutionId Int     @map("institution_id")
  name          String
  surname       String
  patronymic    String?
  email         String  @unique
  password      String
  roles         Role[]
  isActivated   Boolean @default(false) @map("is_activated")

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  moderator   Moderator?
  teacher     Teacher?
  student     Student?
  token       Token[]

  @@map("users")
}

enum Role {
  ADMIN
  STUDENT
  TEACHER
  MODERATOR
}

model Token {
  id      Int      @id @default(autoincrement())
  token   String   @unique
  expires DateTime
  userId  Int      @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

model Moderator {
  id           Int  @id @default(autoincrement())
  userId       Int  @unique @map("user_id")
  accessRights Json @map("access_rights")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("moderators")
}

model Teacher {
  id              Int  @id @default(autoincrement())
  userId          Int  @unique @map("user_id")
  mentoredGroupId Int? @unique @map("mentored_group_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [mentoredGroupId], references: [id], onDelete: SetNull)
  teacherSubjects TeacherSubject[]


  @@map("teachers")
}

model Student {
  id      Int  @id @default(autoincrement())
  userId  Int  @unique @map("user_id")
  groupId Int? @map("group_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@map("students")
}

model Group {
  id Int @id @default(autoincrement())
  name String @unique
  institutionId Int @map("institution_id")


  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  students Student[]
  teacher Teacher?
  subjectGroups SubjectGroup[]

  @@map("groups")
}

model Subject {
  id Int @id @default(autoincrement())
  institutionId Int @map("institution_id")
  name String @unique

  institution Institution @relation(fields: [institutionId], references: [id], onDelete: Restrict)
  subjectGroups SubjectGroup[]
  teacherSubjects TeacherSubject[]
  
  @@map("subjects")
}

model SubjectGroup {
  id Int @id @default(autoincrement())
  subjectId Int @map("subject_id")
  groupId Int @map("group_id")

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([subjectId, groupId])

  @@map("subject_groups")
}

model TeacherSubject {
  id Int @id @default(autoincrement())
  teacherId Int @map("teacher_id")
  subjectId Int @map("subject_id")

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])

  @@map("teacher_subjects")
}