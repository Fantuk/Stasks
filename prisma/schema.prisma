generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Institution {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]

  @@map("institution")
}

model User {
  id            Int     @id @default(autoincrement())
  institutionId Int     @map("institution_id")
  name          String
  surname       String
  patronymic    String
  email         String  @unique
  passwordHash  String  @map("password_hash")
  isActivated   Boolean @default(false) @map("is_activated")

  // Отношения
  institution Institution @relation(fields: [institutionId], references: [id])
  userRoles   UserRole[]
  moderator   Moderator?
  teacher     Teacher?
  student     Student?

  @@map("user")
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String
  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  userId Int @map("user_id")
  roleId Int @map("role_id")

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

model Moderator {
  id           Int  @id @default(autoincrement())
  userId       Int  @unique @map("user_id")
  accessRights Json @map("access_rights")

  user User @relation(fields: [userId], references: [id])

  @@map("moderator")
}

model Teacher {
  id              Int  @id @default(autoincrement())
  userId          Int  @unique @map("user_id")
  mentoredGroupId Int? @unique @map("mentored_group_id")

  user User @relation(fields: [userId], references: [id])

  @@map("teacher")
}

model Student {
  id      Int  @id @default(autoincrement())
  userId  Int  @unique @map("user_id")
  groupId Int? @map("group_id")

  user User @relation(fields: [userId], references: [id])

  @@map("student")
}
